{
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "arrowParens": "always",

  "plugins": ["prettier-plugin-django"],

  "djangoTemplateCurlySpacing": true,
  "djangoTemplateSortAttributes": false,
  "djangoTemplateLineEndings": "lf",
  "djangoTemplateWrapLineLength": 100,
  "djangoTemplateNewLineBetweenStatements": true
}
